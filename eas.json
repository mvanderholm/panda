{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    },
    "internal": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {},
    "internal": {
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "releaseStatus": "draft"
      }
    }
  }
}
