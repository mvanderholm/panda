{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    },
    "internal": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true
    },
    "adhoc": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ABI_FILTER": "arm64-v8a"
      }
    }
  },
  "submit": {
    "production": {},
    "internal": {
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "mvanderholm@gmail.com",
        "ascAppId": "533124525",
        "appleTeamId": "UEUMYG8J48"
      }
    }
  }
}
